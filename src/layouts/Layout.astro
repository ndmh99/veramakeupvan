---
import { ClientRouter } from 'astro:transitions';
import '../styles/style.css';

interface Props {
	title?: string;
}

const { title = "Sophisticated Bridal & Editorial Makeup Artist | Vancouver, BC" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <ClientRouter />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        alabaster: '#F9F7F5',
                        taupe: '#8C7B70',
                        rosegold: '#E2C2B3',
                        deeprose: '#C9A99B',
                    },
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['DM Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-alabaster text-neutral-800 font-sans selection:bg-rosegold selection:text-white overflow-x-hidden">
    <slot />
    
    <script is:inline>
        // Simple reveal animation on scroll
        const setupObserver = () => {
            const observerOptions = {
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('section').forEach(section => {
                section.classList.add('reveal-up');
                observer.observe(section);
            });

            // Add 'active' to hero immediately
            const hero = document.querySelector('.hero');
            if (hero) hero.classList.add('active');
            else {
                const firstSection = document.querySelector('section');
                if(firstSection) firstSection.classList.add('active');
            }
        };

        document.addEventListener('astro:page-load', setupObserver);
    </script>
    <script src="https://platform.simplebotinstall.com/w/chat_plugin.js" data-bot-id="5829" data-astro-rerun></script>
</body>
</html>