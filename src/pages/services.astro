---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Sophisticated Bridal & Editorial Makeup Artist | Vancouver, BC">
    <Header />
    
<!-- THE SERVICE MENU -->
    <section id="menu" class="py-24 bg-alabaster reveal-up active">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-20">
                <span class="text-xs tracking-[0.3em] uppercase text-neutral-400 block mb-4">Investment</span>
                <h2 class="font-serif text-4xl lg:text-5xl text-neutral-900">Signature Artistry Packages</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Package 1 -->
                <div class="bg-white p-10 shadow-[0_20px_50px_rgba(0,0,0,0.05)] flex flex-col h-full transition-transform duration-500 hover:-translate-y-2 hover:text-rose-600">
                    <h3 class="font-serif text-[28px] leading-tight mb-5 ">Bridal &amp; Wedding</h3>
                    <p class="text-[#968478] font-medium text-lg mb-8">From CAD 260</p>
                    <p class="text-neutral-500 text-[15px] leading-relaxed mb-12 flex-grow">A luxury experience including a detailed consultation, preview session, and on-site application on your wedding day.</p>
                    <div class="mt-auto">
                        <a href="#contact" class="inline-block text-[11px] font-bold tracking-[0.2em] uppercase text-neutral-800 mb-3" >BOOK BRIDAL</a>
                        <div class="h-[1px] w-full bg-[#dcc4b6]"></div>
                    </div>
                </div>

                <!-- Package 2 -->
                <div class="bg-white p-10 shadow-[0_20px_50px_rgba(0,0,0,0.05)] flex flex-col h-full transition-transform duration-500 hover:-translate-y-2 hover:text-rose-600">
                    <h3 class="font-serif text-[28px] leading-tight mb-5">Events</h3>
                    <p class="text-[#968478] font-medium mb-8 text-lg">From CAD 180 <span class="text-[10px] font-normal opacity-70">/ person</span></p>
                    <p class="text-neutral-500 text-[15px] leading-relaxed mb-12 flex-grow">Cohesive, elegant looks for your loved ones that complement the overall bridal aesthetic.</p>
                    <div class="mt-auto">
                        <a href="#contact" class="inline-block text-[11px] font-bold tracking-[0.2em] uppercase text-neutral-800 mb-3" >BOOK PARTY</a>
                        <div class="h-[1px] w-full bg-[#dcc4b6]"></div>
                    </div>
                </div>

                <!-- Package 3 -->
                <div class="bg-white p-10 shadow-[0_20px_50px_rgba(0,0,0,0.05)] flex flex-col h-full transition-transform duration-500 hover:-translate-y-2 hover:text-rose-600">
                    <h3 class="font-serif text-[28px] leading-tight mb-5">Editorial &amp;<br>Photoshoot</h3>
                    <p class="text-[#968478] font-medium mb-8 text-lg">Rates per project</p>
                    <p class="text-neutral-500 text-[15px] leading-relaxed mb-12 flex-grow">Specialized techniques for commercial, branding, and editorial shoots. Half-day and full-day rates available.</p>
                    <div class="mt-auto">
                        <a href="#contact" class="inline-block text-[11px] font-bold tracking-[0.2em] uppercase text-neutral-800 mb-3" >INQUIRE EDITORIAL</a>
                        <div class="h-[1px] w-full bg-[#dcc4b6]"></div>
                    </div>
                </div>

                <!-- Package 4 -->
                <div class="bg-white p-10 shadow-[0_20px_50px_rgba(0,0,0,0.05)] flex flex-col h-full transition-transform duration-500 hover:-translate-y-2 hover:text-rose-600">
                    <h3 class="font-serif text-[28px] leading-tight mb-5">1:1 Lessons</h3>
                    <p class="text-[#968478] font-medium mb-8 text-lg">Customized Sessions</p>
                    <p class="text-neutral-500 text-[15px] leading-relaxed mb-12 flex-grow">Master your own routine or refine your professional skills in a personalized hands-on session.</p>
                    <div class="mt-auto">
                        <a href="#contact" class="inline-block text-[11px] font-bold tracking-[0.2em] uppercase text-neutral-800 mb-3" >LEARN MORE</a>
                        <div class="h-[1px] w-full bg-[#dcc4b6]"></div>
                    </div>
                </div>
            </div>
            
            <div class="mt-16 text-center">
                <p class="text-neutral-400 text-sm font-light">* Travel fees apply for locations outside Vancouver &amp; Lower Mainland BC. Bridal trials are highly recommended.</p>
            </div>
        </div>
    </section>

    <!-- THE PROCESS -->
    <section class="py-24 bg-white reveal-up active">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-20">
                <span class="text-xs tracking-[0.3em] uppercase text-taupe block mb-4">Journey</span>
                <h2 class="font-serif text-4xl lg:text-5xl text-neutral-900 italic">How We Work Together</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <div class="relative">
                    <span class="text-8xl font-serif text-alabaster absolute -top-10 -left-4 z-0">01</span>
                    <div class="relative z-10">
                        <h3 class="font-serif text-2xl text-neutral-900 mb-4">Inquiry &amp; Consultation</h3>
                        <p class="text-neutral-500 text-sm leading-relaxed">Reach out with your date and vision. We'll discuss your style preferences, skincare needs, and logistics to ensure a perfect fit.</p>
                    </div>
                </div>
                <div class="relative">
                    <span class="text-8xl font-serif text-alabaster absolute -top-10 -left-4 z-0">02</span>
                    <div class="relative z-10">
                        <h3 class="font-serif text-2xl text-neutral-900 mb-4">The Trial Session</h3>
                        <p class="text-neutral-500 text-sm leading-relaxed">A focused session at my Vancouver studio where we fine-tune your look, test longevity, and finalize your bespoke wedding day palette.</p>
                    </div>
                </div>
                <div class="relative">
                    <span class="text-8xl font-serif text-alabaster absolute -top-10 -left-4 z-0">03</span>
                    <div class="relative z-10">
                        <h3 class="font-serif text-2xl text-neutral-900 mb-4">Celebration Day</h3>
                        <p class="text-neutral-500 text-sm leading-relaxed">I arrive on-site with a calm energy and a full luxury kit, providing a seamless and pampering experience from start to finish.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    

    <!-- CONTACT SECTION -->
    <section id="contact" class="py-24 bg-white reveal-up active">
        <div class="max-w-7xl mx-auto px-6">
            <div class="max-w-3xl mx-auto text-center mb-20">
                <span class="text-xs tracking-[0.3em] uppercase text-taupe block mb-4">Availability</span>
                <h2 class="font-serif text-4xl lg:text-5xl text-neutral-900 italic mb-6">Let's Connect</h2>
                <p class="text-neutral-500 leading-relaxed">To maintain a bespoke experience for every client, I accept a limited number of commissions per season. Please reach out via email for all inquiries, or send a text message before calling for urgent coordination.</p>
            </div>

            <div class="max-w-5xl mx-auto bg-[#111111] py-20 px-8 text-center relative overflow-hidden shadow-2xl">
                <!-- Atmospheric Background Elements -->
                <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-white/[0.02] blur-[120px] rounded-full -mr-32 -mt-32"></div>
                <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-rosegold/[0.03] blur-[100px] rounded-full -ml-20 -mb-20"></div>

                <div class="relative z-10">
                    <span class="text-[10px] tracking-[0.4em] uppercase text-taupe font-bold block mb-8 text-sm">Collaboration</span>
                    <h2 class="font-serif text-3xl md:text-5xl text-white italic mb-8 leading-tight">Ready to design your signature look?</h2>
                    <p class="text-neutral-400 text-sm md:text-base leading-relaxed max-w-xl mx-auto mb-12">
                        I am currently accepting commissions for the seasons. Let's create something timeless together.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                        <a href="mailto:veramakeupvan@gmail.com" class="w-full sm:w-auto px-12 py-5 bg-white text-neutral-900 text-[10px] font-bold tracking-[0.25em] uppercase transition-all duration-500 hover:bg-rosegold hover:text-white" >
                            Inquire via Email
                        </a>
                        <a href="sms:+17789510631" class="w-full sm:w-auto px-12 py-5 border border-neutral-800 text-white text-[10px] font-bold tracking-[0.25em] uppercase transition-all duration-500 hover:border-white/40 hover:bg-white/5" >
                            Text Message
                        </a>
                    </div>
                    <p class="text-[10px] text-rosegold italic tracking-wider mt-4">* Please note: Text only. Phone calls are not accepted.</p>
                    <p class="text-[10px] text-neutral-500 tracking-wider mt-4 uppercase">* By submitting an inquiry, you agree to our <a href="/policies/" class="underline hover:text-white transition-colors">Booking Policies & Terms</a> and <a href="/privacy/" class="underline hover:text-white transition-colors">Privacy Policy</a>.</p>
                </div>
            </div>
        </div>
    </section>
    

    <!-- FOOTER -->
    
    <Footer />
</Layout>
