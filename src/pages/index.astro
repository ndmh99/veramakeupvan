---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_MEDIA } from '../config/media.ts';

const heroSliderImages = SITE_MEDIA.portfolio.gallery.filter(img => 
    img.category === 'Bridal' || img.category === 'Events'
).slice(0, 6);
---

<Layout 
    title="Sophisticated Bridal & Editorial Makeup Artist | Vancouver, BC"
    description="Vera Makeup Studio: Specializing in effortless, editorial glam for modern brides. Top-rated luxury makeup artist in Metro Vancouver and surrounding areas."
>
    <style>
        .hero-slider-container {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .hero-slider-container::-webkit-scrollbar {
            display: none;
        }
    </style>
    <!-- Structured Data -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Vera Makeup Studio",
        "image": "https://veramakeupvan.com/assets/images/thumbnail.png",
        "@id": "https://veramakeupvan.com/",
        "url": "https://veramakeupvan.com/",
        "telephone": "+16045187121",
        "priceRange": "$$$",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Vancouver",
          "addressRegion": "BC",
          "addressCountry": "CA"
        },
        "sameAs": [
          "https://www.instagram.com/veramakeup_artistry/"
        ]
      }
    </script>
    <Header />
    
<!-- HERO SECTION -->
    <section class="relative min-h-screen flex items-center pt-20 reveal-up active">
        <div class="grid grid-cols-1 lg:grid-cols-2 w-full h-full min-h-[calc(100vh-80px)]">
            <div class="flex flex-col justify-center px-6 lg:px-20 py-20 order-2 lg:order-1">
                <span class="text-sm tracking-[0.3em] uppercase text-taupe mb-6 block font-medium">Makeup Artist · Vancouver</span>
                <h1 class="font-serif text-5xl lg:text-7xl leading-[1.1] text-neutral-900 mb-8">
                    Effortless, Editorial <br> Glam for <span class="italic">Modern Brides</span>
                </h1>
                <p class="text-lg text-neutral-600 mb-10 leading-relaxed max-w-lg">
                    Ensures you feel like yourself—just elevated.
                </p>
                
                <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-6 mb-12">
                    <a href="#contact" class="bg-neutral-900 text-white px-8 py-5 text-sm tracking-widest uppercase hover:bg-neutral-800 transition-all text-center" >
                        Check My Availability
                    </a>
                    <a href="/portfolio/" class="border border-neutral-200 px-8 py-5 text-sm tracking-widest uppercase hover:bg-neutral-50 transition-all text-center" >
                        View Portfolio
                    </a>
                </div>

                <div class="flex items-center space-x-6 text-[11px] tracking-[0.15em] uppercase text-taupe border-t border-neutral-200 pt-8">
                    <div class="flex flex-col">
                        <span class="font-bold text-neutral-900 mb-1">Location</span>
                        <span>Vancouver &amp; Lower Mainland BC</span>
                    </div>
                    <div class="w-px h-8 bg-neutral-200"></div>
                    <div class="flex flex-col">
                        <span class="font-bold text-neutral-900 mb-1">Trusted By</span>
                        <span class="">200+ Happy CLIENTs</span>
                    </div>
                    <div class="w-px h-8 bg-neutral-200"></div>
                    <div class="flex flex-col">
                        <span class="font-bold text-neutral-900 mb-1">Experience</span>
                        <span>5+ Professional Years</span>
                    </div>
                </div>
            </div>
            
            <div class="relative min-h-[500px] lg:min-h-full order-1 lg:order-2 overflow-hidden group/hero">
                <div id="hero-slider" class="hero-slider-container absolute inset-0 flex overflow-x-auto snap-x snap-mandatory scroll-smooth">
                    {heroSliderImages.map((image, index) => (
                        <div class="flex-shrink-0 w-full h-full snap-start relative">
                             <img 
                                src={image.url} 
                                alt={image.alt}
                                class="w-full h-full object-cover object-top"
                                style="object-position: center 30%;"
                                loading={index === 0 ? "eager" : "lazy"}
                            />
                        </div>
                    ))}
                </div>
                
                <!-- Slider Dots -->
                <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex space-x-3 z-20">
                    {heroSliderImages.map((_, i) => (
                        <button 
                            class={`w-2 h-2 rounded-full border border-white transition-all hero-dot ${i === 0 ? 'bg-white w-5' : 'bg-white/40'}`}
                            data-index={i}
                            aria-label={`Go to slide ${i + 1}`}
                        ></button>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <script is:inline>
      const initHeroSlider = () => {
        const slider = document.getElementById('hero-slider');
        const dots = document.querySelectorAll('.hero-dot');
        if (!slider || dots.length === 0) return;

        let currentIndex = 0;
        const totalSlides = dots.length;
        let interval;
        let isUserInteracting = false;

        const updateDots = (index) => {
          dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add('bg-white', 'w-5');
              dot.classList.remove('bg-white/40');
            } else {
              dot.classList.remove('bg-white', 'w-5');
              dot.classList.add('bg-white/40');
            }
          });
        };

        const goToSlide = (index) => {
          if (index < 0 || index >= totalSlides) return;
          currentIndex = index;
          slider.scrollTo({
            left: slider.offsetWidth * index,
            behavior: 'smooth'
          });
          updateDots(index);
        };

        const nextSlide = () => {
          currentIndex = (currentIndex + 1) % totalSlides;
          goToSlide(currentIndex);
        };

        const startAutoSlide = () => {
          stopAutoSlide();
          interval = setInterval(nextSlide, 5000);
        };

        const stopAutoSlide = () => {
          if (interval) clearInterval(interval);
        };

        // Update current index based on scroll position (manual swipe)
        let scrollTimeout;
        const onScroll = () => {
            if (scrollTimeout) clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => {
                const index = Math.round(slider.scrollLeft / slider.offsetWidth);
                if (index !== currentIndex && index >= 0 && index < totalSlides) {
                    currentIndex = index;
                    updateDots(currentIndex);
                }
            }, 100);
        };

        slider.addEventListener('scroll', onScroll, { passive: true });

        // Pause on interaction
        const onInteractionStart = () => {
            stopAutoSlide();
            isUserInteracting = true;
        };

        slider.addEventListener('touchstart', onInteractionStart, { passive: true });
        slider.addEventListener('mousedown', onInteractionStart);

        const resume = () => {
            if (isUserInteracting) {
                isUserInteracting = false;
                startAutoSlide();
            }
        };

        slider.addEventListener('touchend', resume, { passive: true });
        slider.addEventListener('mouseup', resume);
        slider.addEventListener('mouseleave', resume);

        // Dot clicks
        dots.forEach((dot, i) => {
          dot.addEventListener('click', () => {
            goToSlide(i);
            startAutoSlide();
          });
        });

        // Initialize
        startAutoSlide();

        // Handle window resize
        const onResize = () => {
            goToSlide(currentIndex);
        };
        window.addEventListener('resize', onResize);
      };

      document.addEventListener('astro:page-load', initHeroSlider);
    </script>

    <!-- NICHE POSITIONING -->
    <section class="py-16 bg-white reveal-up active">
        <div class="max-w-7xl mx-auto px-6">
